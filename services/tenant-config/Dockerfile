FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /tenant-config ./cmd/main.go

# ────────────────────────────────────────────────
FROM alpine:3.21

RUN addgroup -S app && adduser -S app -G app

WORKDIR /app
COPY --from=builder /tenant-config .

USER app

EXPOSE 50052 9091

ENTRYPOINT ["./tenant-config"]